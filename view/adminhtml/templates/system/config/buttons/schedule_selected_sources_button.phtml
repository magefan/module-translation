        <ul style="margin: 8px 0 0 18px; list-style: disc;">
            <li><code>--type=product</code> &mdash; <?= $escaper->escapeHtml(__('Entity type to schedule (e.g. product, category, page).')) ?></li>
            <li><code>--entity-ids=10,20</code> &mdash; <?= $escaper->escapeHtml(__('Comma-separated list of entity IDs to translate. Omit to schedule all entities of the given type.')) ?></li>
            <li><code>--store-ids=2,3</code> &mdash; <?= $escaper->escapeHtml(__('Comma-separated list of store view IDs to translate into. Omit to use all configured store views.')) ?></li>
            <li><code>--fields=name,description</code> &mdash; <?= $escaper->escapeHtml(__('Comma-separated list of attribute fields to translate. Omit to translate all translatable fields.')) ?></li>
