<div class="pp-buttons-container">
    <button type="button" id="<?= $escaper->escapeHtml($block->getId()) ?>">
        <span><span><span><?= $escaper->escapeHtml($block->getButtonLabel()) ?></span></span></span>
    </button>
</div>

<?php $script = "
    require(['jquery', 'Magento_Ui/js/modal/confirm'], function($, confirmation) {
        $('#" . $escaper->escapeHtml($block->getId()) . "').on('click', function(event){
            event.preventDefault;
            var baseUrl = '" . $escaper->escapeUrl($block->getScheduleSelectedSourcesUrl()) . "';
            var selectEl = document.getElementById('mftranslation_auto_translation_schedule_translation_source');
            var selectedOptions = selectEl ? Array.from(selectEl.selectedOptions) : [];
            var selected = selectedOptions.map(function(o) { return o.value; });
            var query = selected.map(function(v) { return 'sources[]=' + encodeURIComponent(v); }).join('&');
            var url = query ? baseUrl + '?' + query : baseUrl;
            var listHtml = selectedOptions.length
                ? '<ul style=\"margin:10px 0 0 18px;list-style:disc\">' + selectedOptions.map(function(o) { return '<li>' + $('<div>').text(o.text).html() + '</li>'; }).join('') + '</ul>'
                : '<p style=\"margin-top:8px;color:#e22626\">" . $escaper->escapeHtml(__('No sources selected.')) . "</p>';
            confirmation({
                title: '" . $escaper->escapeHtml(__('Schedule Selected Sources')) . "',
                content: '" . $escaper->escapeHtml(__('The following sources will be scheduled for translation:')) . "' + listHtml,
                actions: {
                    confirm: function () {
                        if (selectedOptions.length) { window.location = url; }
                    },
                }
            });
        });
    });
";?>


<?= /* @noEscape */ $mfSecureRenderer->renderTag('script', [], $script, false) ?>

